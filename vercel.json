{
  "version": 2,
  "installCommand": "npm install",
  "buildCommand": "cd frontend && npx vite build",
  "outputDirectory": "frontend/dist",
  "routes": [
    { "src": "/api/(.*)", "dest": "https://backend-production-162ba.up.railway.app/api/$1" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
