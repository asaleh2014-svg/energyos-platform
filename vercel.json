{
  "version": 2,
  "experimentalServices": {
    "frontend": {
      "root": "frontend",
      "routePrefix": "/",
      "framework": "vite"
    }
  },
  "rewrites": [
    { "source": "/api/:path*", "destination": "https://backend-production-162ba.up.railway.app/api/:path*" },
    { "source": "/((?!assets/).*)", "destination": "/index.html" }
  ]
}
